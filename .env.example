# --- Core ---
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret

# --- Database (Prisma/Postgres) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# --- AI Provider ---
# IMPORTANT: keep this server-side only, do not expose to browser bundles.
OPENAI_API_KEY=sk-...
# Optional reverse proxy endpoint
OPENAI_API_PROXY=

# --- Azure Speech ---
# IMPORTANT: keep this server-side only.
AZURE_SECRET=
AZURE_REGION=
